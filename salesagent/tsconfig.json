{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@auth/*": ["src/auth/*"],
      "@users/*": ["src/users/*"],
      "@tenants/*": ["src/tenants/*"],
      "@agents/*": ["src/agents/*"],
      "@conversations/*": ["src/conversations/*"],
      "@leads/*": ["src/leads/*"],
      "@skills/*": ["src/skills/*"],
      "@tools/*": ["src/tools/*"],
      "@mcp/*": ["src/mcp/*"],
      "@rag/*": ["src/rag/*"],
      "@knowledge/*": ["src/knowledge/*"],
      "@workflows/*": ["src/workflows/*"],
      "@common/*": ["src/common/*"]
    }
  },
  "exclude": ["node_modules", "dist", "test/**/*", "**/*.spec.ts", "**/__tests__/**/*"]
}
