{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testMatch": ["**/test/integration/**/*.spec.ts"],
  "transform": { "^.+\\.(t|j)s$": "ts-jest" },
  "testEnvironment": "node",
  "testTimeout": 30000,
  "maxWorkers": 1,
  "verbose": true,
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1"
  }
}
